# Server
PORT=3003
PUBLIC_BASE_URL=https://your-host.example.com

# Google Sheets
GOOGLE_SPREADSHEET_ID=
# Either path to service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# Or base64-encoded JSON (overrides file if set):
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Calendar (optional — meeting invites via email)
# Share a team calendar with the service account, or use Workspace domain-wide delegation.
GOOGLE_CALENDAR_ID=
# Workspace user email to impersonate (recommended — required for attendee invites in most orgs)
GOOGLE_CALENDAR_SUBJECT=
GOOGLE_CALENDAR_TIMEZONE=Asia/Bangkok

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# OpenAI (agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron (optional overrides; defaults in config)
# CRON_FINANCE=0 9 * * *
# CRON_DOCUMENTS=5 9 * * *
# CRON_MEETINGS=*/15 * * * *
# CRON_ESCALATION=30 9 * * *

# Reminders / escalation
FINANCE_REMIND_DAYS_BEFORE=3
FINANCE_ESCALATE_USER_DAYS=3
FINANCE_ESCALATE_MANAGER_DAYS=7
MEETING_NOTIFY_HOURS_BEFORE=24
ADMIN_LINE_USER_ID=

# Ops dashboard (optional — if set, require ?token= or X-Dashboard-Token header)
# DASHBOARD_TOKEN=

# Agent
# AGENT_MAX_TOOL_ROUNDS=5
